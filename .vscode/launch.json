{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run app (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "serverReadyAction": {
        "pattern": "Running on http://127\\.0\\.0\\.1:([0-9]+)",
        "uriFormat": "http://127.0.0.1:%s/",
        "action": "openExternally"
      }
    }
  ]
}
